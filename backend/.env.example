# Copy to backend/.env and fill in — never commit the real .env file.

# Choose one: huggingface_api (free, needs token) | local_transformers (free, offline) | anthropic (paid)
LLM_PROVIDER=huggingface_api

# --- huggingface_api ---
# Free token: https://huggingface.co/settings/tokens (read scope is enough)
HF_API_TOKEN=
HF_INFERENCE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- local_transformers (no token needed, downloads once then runs offline) ---
LOCAL_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct

# --- anthropic (optional, paid) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Scraping ---
SCRAPE_HEADLESS=true
SCRAPE_MAX_JOBS=40


ADZUNA_APP_ID="6af77c45"
ADZUNA_APP_KEY="381ed49f7882cd2bdce0ab31ff1805ae"
